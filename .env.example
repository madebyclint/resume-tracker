# -- OpenAI ------------------------------------------------------------------
# Get your API key from https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-...

# Chat completions endpoint (default works for OpenAI; swap for Azure/proxy)
VITE_OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Must support vision for image/screenshot uploads -- use gpt-4o or gpt-4-turbo
VITE_OPENAI_MODEL=gpt-4o

# -- Backend API --------------------------------------------------------------
# In development the Vite dev server talks directly to the API server
VITE_API_URL=http://localhost:3001/api

# In production (Railway) set this to your Railway domain, e.g.:
# VITE_API_URL=https://resume-tracker-production.up.railway.app/api