# -- Server ------------------------------------------------------------------
NODE_ENV=development
PORT=3001

# -- Database ----------------------------------------------------------------
# Local Postgres : postgresql://user:password@localhost:5432/resume_tracker
# Railway Postgres: copy the DATABASE_URL from the Railway Variables tab
DATABASE_URL=postgresql://username:password@host:5432/database

# -- Auth --------------------------------------------------------------------
# Long random string used to sign JWTs -- generate with: openssl rand -hex 32
# NEVER commit the real value; keep it out of source control
JWT_SECRET=change-me-use-openssl-rand-hex-32

# -- CORS --------------------------------------------------------------------
# Comma-separated list of allowed frontend origins (no trailing slashes)
# Add your Railway domain in production, e.g.:
#   ALLOWED_ORIGINS=http://localhost:5173,https://resume-tracker-production.up.railway.app
ALLOWED_ORIGINS=http://localhost:5173

# -- File uploads ------------------------------------------------------------
# Max body size accepted by Express (bytes). 10 MB = 10485760
MAX_FILE_SIZE=10485760

# -- Rate limiting -----------------------------------------------------------
# Window in milliseconds (900000 = 15 min) and max requests per IP per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100